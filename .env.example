NODE_ENV = development
PORT = 5001
MONGO_URI = mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
JWT_SECRET = <generate a long random string, e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))">

# Resend (email reminders) — get your API key at resend.com
RESEND_API_KEY = re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM = Quackel <you@yourdomain.com>
FRONTEND_URL = http://localhost:3000
